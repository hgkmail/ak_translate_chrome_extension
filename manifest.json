{
  "name": "AK Translate Extension",
  "description": "AK Translate Extension",
  "version": "0.0.1",
  "manifest_version": 3,
  "action": {
    "default_title": "Click to open panel"
  },
  "permissions": [
    "storage",
    "sidePanel",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "pages/side_panel/index.html"
  },
  "options_page": "pages/options/index.html",
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "pages/content_script/index.js"
      ],
      "css": [
        "pages/content_script/styles.css"
      ],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "images/icon16.png",
    "32": "images/icon32.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  }
}
